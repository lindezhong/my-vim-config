# ╚═══════════════════════════════════════════════════════════════════════════════╝
# 
# # css样式定位
# ## 继承
#
# css属性是否可以被继承属性表
#  ┌────────┬───────────────────────────────────┬───────────────────────────────────┐
#  │ 分类   │          可继承                   │          不可继承                 │
#  ├────────┼───────────────────────────────────┼───────────────────────────────────┤
#  │ 文本   │ color, font-size, font-family,    │ -                                 │
#  │        │ font-weight, line-height,         │                                   │
#  │        │ letter-spacing, word-spacing,     │                                   │
#  │        │ text-align, text-decoration,      │                                   │
#  │        │ text-transform, text-shadow       │                                   │
#  ├────────┼───────────────────────────────────┼───────────────────────────────────┤
#  │ 字体   │ font-style, font-variant          │ -                                 │
#  ├────────┼───────────────────────────────────┼───────────────────────────────────┤
#  │ 列表   │ list-style-type,                  │ -                                 │
#  │        │ list-style-position,              │                                   │
#  │        │ list-style-image                  │                                   │
#  ├────────┼───────────────────────────────────┼───────────────────────────────────┤
#  │ 表格   │ border-collapse, caption-side,    │ -                                 │
#  │        │ empty-cells, table-layout         │                                   │
#  ├────────┼───────────────────────────────────┼───────────────────────────────────┤
#  │ 盒模型 │ -                                 │ width, height,                    │
#  │        │                                   │ margin, padding,                  │
#  │        │                                   │ border,                           │
#  │        │                                   │ min/max-width, min/max-height     │
#  ├────────┼───────────────────────────────────┼───────────────────────────────────┤
#  │ 定位   │ -                                 │ position, top, right,             │
#  │        │                                   │ bottom, left,                     │
#  │        │                                   │ z-index, float, clear             │
#  ├────────┼───────────────────────────────────┼───────────────────────────────────┤
#  │ 背景   │ -                                 │ background-color,                 │
#  │        │                                   │ background-image,                 │
#  │        │                                   │ background-repeat,                │
#  │        │                                   │ background-position,              │
#  │        │                                   │ background-size                   │
#  ├────────┼───────────────────────────────────┼───────────────────────────────────┤
#  │ 显示   │ visibility, cursor                │ display, overflow,                │
#  │        │                                   │ vertical-align                    │
#  ├────────┼───────────────────────────────────┼───────────────────────────────────┤
#  │ 动效   │ -                                 │ transform, transition,            │
#  │        │                                   │ animation                         │
#  └────────┴───────────────────────────────────┴───────────────────────────────────┘
# 
# ### 控制继承的特殊值
#  ┌──────────────┬──────────────────────────────┬────────────────────┐
#  │      值      │             作用             │     简单理解       │
#  ├──────────────┼──────────────────────────────┼────────────────────┤
#  │ inherit      │ 继承父元素的属性值           │ 和父元素一样       │
#  ├──────────────┼──────────────────────────────┼────────────────────┤
#  │ initial      │ 重置为CSS规范的初始值        │ 使用CSS默认值      │
#  ├──────────────┼──────────────────────────────┼────────────────────┤
#  │ revert       │ 重置为浏览器的默认样式       │ 使用浏览器默认值   │
#  ├──────────────┼──────────────────────────────┼────────────────────┤
#  │ revert-layer │ 重置为上一层叠层的值         │ 使用上一层的值     │
#  ├──────────────┼──────────────────────────────┼────────────────────┤
#  │ unset        │ 可继承则inherit，否则initial │ 自然处理(默认值)   │
#  └──────────────┴──────────────────────────────┴────────────────────┘
#
# 典型使用场景表
#  ┌────────────────────┬──────────────┬─────────────────────────────────────────────────┐
#  │        场景        │   使用的值   │                    代码示例                     │
#  ├────────────────────┼──────────────┼─────────────────────────────────────────────────┤
#  │ 链接继承父元素颜色 │ inherit      │ a { color: inherit; text-decoration: inherit; } │
#  ├────────────────────┼──────────────┼─────────────────────────────────────────────────┤
#  │ 重置按钮样式       │ initial      │ button { all: initial; }                        │
#  ├────────────────────┼──────────────┼─────────────────────────────────────────────────┤
#  │ 恢复标题默认边距   │ revert       │ h1 { margin: revert; }                          │
#  ├────────────────────┼──────────────┼─────────────────────────────────────────────────┤
#  │ 简化批量重置       │ unset        │ * { margin: unset; padding: unset; }            │
#  ├────────────────────┼──────────────┼─────────────────────────────────────────────────┤
#  │ 强制继承边框       │ inherit      │ .child { border: inherit; }                     │
#  ├────────────────────┼──────────────┼─────────────────────────────────────────────────┤
#  │ 层叠层回退         │ revert-layer │ @layer override { .el { color: revert-layer; }} │
#
#
# ## css选择器
#  ┌────────────┬─────────────────┬──────────────────────┬───────────────────────┬─────────────────────────────────┐
#  │    分类    │   选择器类型    │         语法         │         示例          │           说明                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 基本选择器 │ 元素选择器      │ element              │ div                   │ 选择所有指定元素                │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 基本选择器 │ 类选择器        │ .class               │ .container            │ 选择所有指定类的元素            │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 基本选择器 │ ID 选择器       │ #id                  │ #header               │ 选择指定 ID 的元素              │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 基本选择器 │ 通配符选择器    │ *                    │ *                     │ 选择所有元素                    │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 基本选择器 │ 分组选择器      │ selector1, selector2 │ h1, h2                │ 选择多个选择器匹配的元素        │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 组合选择器 │ 后代选择器      │ ancestor descendant  │ div p                 │ 选择所有后代元素                │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 组合选择器 │ 子选择器        │ parent > child       │ ul > li               │ 选择直接子元素                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 组合选择器 │ 相邻兄弟选择器  │ element + sibling    │ h1 + p                │ 选择紧接的兄弟元素              │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 组合选择器 │ 通用兄弟选择器  │ element ~ sibling    │ h1 ~ p                │ 选择之后的所有兄弟元素          │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 属性选择器 │ 存在属性        │ [attr]               │ [data-id]             │ 选择有指定属性的元素            │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 属性选择器 │ 存在属性        │ element[attr]        │ a[data-id]            │ 属性选择器可与元素选择器合用    │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 属性选择器 │ 精确匹配        │ [attr="value"]       │ [type="text"]         │ 属性值精确匹配                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 属性选择器 │ 包含匹配        │ [attr~="value"]      │ [class~="active"]     │ 属性值包含指定词                │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 属性选择器 │ 开头匹配        │ [attr^="value"]      │ [href^="https"]       │ 属性值以指定值开头              │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 属性选择器 │ 结尾匹配        │ [attr$="value"]      │ [src$=".jpg"]         │ 属性值以指定值结尾              │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 属性选择器 │ 包含字符串      │ [attr*="value"]      │ [href*="google"]      │ 属性值包含指定字符串            │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 属性选择器 │ 连字符开头      │ [attr|="value"]      │ [lang|="zh"]          │ 属性值以 value- 开头            │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 链接伪类   │ 未访问链接      │ :link                │ a:link                │ 未访问的链接                    │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 链接伪类   │ 已访问链接      │ :visited             │ a:visited             │ 已访问的链接                    │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 链接伪类   │ 焦点状态        │ :focus               │ input:focus           │ 获得焦点时                      │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 链接伪类   │ 鼠标悬停        │ :hover               │ button:hover          │ 鼠标悬停时                      │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 链接伪类   │ 激活状态        │ :active              │ button:active         │ 被激活时                        │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 第一个子元素    │ :first-child         │ li:first-child        │ 第一个子元素                    │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 最后一个子元素  │ :last-child          │ li:last-child         │ 最后一个子元素                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 第 n 个子元素   │ :nth-child(n)        │ li:nth-child(2)       │ 第 n 个子元素                   │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 奇偶子元素      │ :nth-child(odd/even) │ li:nth-child(odd)     │  odd: 奇数项, even: 偶数项      │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 倒数第 n 个     │ :nth-last-child(n)   │ li:nth-last-child(2)  │ 倒数第 n 个子元素               │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 唯一子元素      │ :only-child          │ p:only-child          │ 唯一的子元素                    │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 第一个类型      │ :first-of-type       │ p:first-of-type       │ 同类型中的第一个                │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 最后一个类型    │ :last-of-type        │ p:last-of-type        │ 同类型中的最后一个              │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 第 n 个类型     │ :nth-of-type(n)      │ p:nth-of-type(2)      │ 同类型中的第 n 个               │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 倒数第 n 个类型 │ :nth-last-of-type(n) │ p:nth-last-of-type(2) │ 同类型倒数第 n 个               │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 唯一类型        │ :only-of-type        │ img:only-of-type      │ 唯一的该类型元素                │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 根元素          │ :root                │ :root                 │ 文档的根元素                    │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 空元素          │ :empty               │ div:empty             │ 没有子元素的元素                │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 结构伪类   │ 目标元素        │ :target              │ section:target        │ 锚点目标元素                    │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 启用状态        │ :enabled             │ input:enabled         │ 启用的表单元素                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 禁用状态        │ :disabled            │ input:disabled        │ 禁用的表单元素                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 选中状态        │ :checked             │ input:checked         │ 选中的复选框/单选框             │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 必填字段        │ :required            │ input:required        │ 必填的表单元素                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 可选字段        │ :optional            │ input:optional        │ 可选的表单元素                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 验证通过        │ :valid               │ input:valid           │ 验证通过的元素                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 验证失败        │ :invalid             │ input:invalid         │ 验证失败的元素                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 范围内          │ :in-range            │ input:in-range        │ 值在范围内                      │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 范围外          │ :out-of-range        │ input:out-of-range    │ 值超出范围                      │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 只读状态        │ :read-only           │ input:read-only       │ 只读元素                        │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 表单伪类   │ 读写状态        │ :read-write          │ input:read-write      │ 可读写元素                      │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 逻辑伪类   │ 非选择器        │ :not(selector)       │ :not(.active)         │ 不匹配指定选择器                │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 逻辑伪类   │ 父元素选择器    │ :has(selector)       │ div:has(p)            │ 包含指定子元素                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 权重伪类   │ 匹配伪类选择器  │ :is(selector)        │ :is(.active)          │ 权重 = 最高的权重(选中selector) │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 权重伪类   │ 条件伪类选择器  │ :where(selector)     │ :where(#active)       │ 权重 = 0(选中selector)          │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 伪元素     │ 首字母          │ ::first-letter       │ p::first-letter       │ 第一个字母                      │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 伪元素     │ 第一行          │ ::first-line         │ p::first-line         │ 第一行文本                      │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 伪元素     │ 前插入          │ ::before             │ p::before             │ 元素前插入内容                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 伪元素     │ 后插入          │ ::after              │ p::after              │ 元素后插入内容                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 伪元素     │ 选中文本        │ ::selection          │ p::selection          │ 用户选中的文本                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ 伪元素     │ 占位符          │ ::placeholder        │ input::placeholder    │ 表单占位符文本                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ CSS3 新增  │ 焦点区域        │ :focus-within        │ form:focus-within     │ 子元素获得焦点                  │
#  ├────────────┼─────────────────┼──────────────────────┼───────────────────────┼─────────────────────────────────┤
#  │ CSS3 新增  │ 焦点可见        │ :focus-visible       │ button:focus-visible  │ 明确获得焦点                    │
#  └────────────┴─────────────────┴──────────────────────┴───────────────────────┴─────────────────────────────────┘
#
# ## 权重和层叠
# 
# ### 权重表
# ┌─────────────────┬────────────────────────┬─────────────┬────────────┬────────┐
# │    权重格式     │          示例          │ 选择器类型  │  层叠顺序  │  数值  │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ !important(∞)   │ color: red !important; │ !important  │ 最高优先级 │ ∞      │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 行内样式(1000)  │ <p style="">           │ 行内样式    │ 第2优先级  │ 1000   │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ ID(100)         │ #header                │ 单个ID      │ 第3优先级  │ 100    │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ ID+类(110)      │ #nav .active           │ ID+类       │ 第3优先级  │ 110    │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 标签+ID(101)    │ div#header             │ 标签+ID     │ 第3优先级  │ 101    │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ ID+标签+类(111) │ #nav a.link            │ ID+标签+类  │ 第3优先级  │ 111    │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ ID+ID(200)      │ #header#nav            │ ID+ID       │ 第3优先级  │ 200    │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 类(10)          │ .class                 │ 单个类      │ 第4优先级  │ 10     │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 属性(10)        │ [type="text"]          │ 属性选择器  │ 第4优先级  │ 10     │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 伪类(10)        │ :hover                 │ 单个伪类    │ 第4优先级  │ 10     │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 类+类(20)       │ .btn.active            │ 类+类       │ 第4优先级  │ 20     │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 类+伪类(20)     │ .btn:hover             │ 类+伪类     │ 第4优先级  │ 20     │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 标签+类(11)     │ div.class              │ 标签+类     │ 第4优先级  │ 11     │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 标签+伪类(11)   │ a:hover                │ 标签+伪类   │ 第4优先级  │ 11     │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 标签+属性(11)   │ a[data-id]             │ 标签+属性   │ 第4优先级  │ 11     │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 元素(1)         │ div                    │ 单个标签    │ 第5优先级  │ 1      │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 标签+标签(2)    │ div p                  │ 后代选择器  │ 第5优先级  │ 2      │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 标签+标签(2)    │ ul > li                │ 子代选择器  │ 第5优先级  │ 2      │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 标签+标签(2)    │ h1 + p                 │ 相邻兄弟    │ 第5优先级  │ 2      │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 标签+标签(2)    │ h1 ~ p                 │ 通用兄弟    │ 第5优先级  │ 2      │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 标签+伪元素(2)  │ p::before              │ 标签+伪元素 │ 第5优先级  │ 2      │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 伪元素(1)       │ ::before               │ 单个伪元素  │ 第5优先级  │ 1      │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 通配符(0)       │ *                      │ 通配符      │ 第6优先级  │ 0      │
# ├─────────────────┼────────────────────────┼─────────────┼────────────┼────────┤
# │ 继承            │ -                      │ 继承样式    │ 第7优先级  │ 无权重 │
# └─────────────────┴────────────────────────┴─────────────┴────────────┴────────┘
#
# ### 层联级
# ┌────────────┬──────────┬──────────────────────────────────────┬────────────────────────────┐
# │    分类    │ 知识点   │              详细说明                │        示例代码            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ @import    │ 定义     │ 导入外部 CSS 文件到当前样式表        │ @import url('style.css')   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 作用     │ 模块化 CSS，分离样式文件             │ 大文件拆分为多个小文件     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 位置     │ 必须在所有 CSS 规则之前（除@charset）│ @import在前；body{}在后 ✓  │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 语法     │ url() / '' / 带媒体查询 / 带条件     │ @import 'print.css' print  │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 层支持   │ 可导入到指定层                       │ @import url() layer(name)  │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 性能     │ 会阻塞渲染，建议用 <link>            │ 不推荐大量使用             │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ @media基础 │ 定义     │ 媒体查询，根据设备特性应用不同样式   │ @media (min-width:768px){} │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 作用     │ 响应式设计，适配不同设备             │ 手机/平板/桌面不同样式     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 位置     │ 可在 CSS 任何位置                    │ 可在样式表内部或外部       │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 语法     │ min/max-width / orientation /        │ @media (orientation:       │
# │            │          │ prefers-color-scheme / print         │ portrait) {}               │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 逻辑符   │ and / or / not / only                │ @media (min-w:768px) and   │
# │            │          │                                      │ (max-w:1024px)             │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 常用     │ 移动<768px / 平板768-1024px /        │ @media (max-width:767px)   │
# │            │ 断点     │ 桌面>1024px                          │ @media (min-w:768px) and   │
# │            │          │                                      │ (max-w:1024px)             │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ @import与  │ 导入到层 │ 将外部 CSS 文件导入到指定层          │ @import url('reset.css')   │
# │ @layer     │          │                                      │ layer(reset)               │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 匿名层   │ 不指定层名，创建匿名层               │ @import url('a.css') layer │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 多层导入 │ 可以分别导入不同层                   │ @import url('a.css')       │
# │            │          │                                      │ layer(a); @import url('b') │
# │            │          │                                      │ layer(b)                   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 完整示例 │ 在主样式表开头使用                   │ @import url('reset.css')   │
# │            │          │                                      │ layer(reset); @import url  │
# │            │          │                                      │ ('base.css') layer(base)   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 注意     │ ⚠️ @import 必须在所有 CSS 规则之前    │ ✓ @import在前; ✗ @import在 │
# │            │          │                                      │ 后（无效）                 │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ @media与   │ 写法A    │ 媒体查询在外，整个层只在媒体查询     │ @media (min-w:768px) {     │
# │ @layer     │          │ 生效时存在                           │ @layer responsive {...}}   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 写法B    │ 层在外，媒体查询只是层内的一部分     │ @layer responsive { @mediaa│
# │            │          │                                      │ (min-w:768px) {...}}       │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 写法C    │ 先声明，再组合使用                   │ @layer res; @media {...} { │
# │            │          │                                      │ @layer res {...}}          │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 写法D    │ 多层共用一个媒体查询                 │ @media {...} { @layer a {}}│
# │            │          │                                      │ @layer b {}}               │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 写法E    │ 匿名层 + 媒体查询                    │ @media {...} { @layer {.}} │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 推荐     │ 优先使用写法A                        │ 更清晰，层完全受媒体查询   │
# │            │          │                                      │ 控制                       │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ @layer基础 │ 全称     │ CSS Cascading Layers（级联层）       │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 版本     │ CSS Cascading and Inheritance L5     │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 作用     │ 控制样式优先级层级，解决样式冲突     │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 浏览器   │ Chrome99+ / Firefox97+ / Safari15.4+ │                            │
# │            │          │ / Edge99+                            │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ @layer语法 │ 声明单个 │ @layer name;                         │ @layer base;               │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 声明多个 │ @layer a,b,c; 逗号分隔               │ @layer reset,base,comp;    │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 声明并   │ @layer name{rules}                   │ @layer base{body{font:16px │
# │            │ 定义     │                                      │ }}                         │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 匿名层   │ @layer{rules} 无名称                 │ @layer{color:red;}         │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 嵌套层   │ @layer outer{@layer inner;}          │ @layer framework.theme {}  │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ @import+   │ 组合     │ 导入响应式样式                       │ @import url('mobile.css')  │
# │ @media     │ 使用     │                                      │ layer(base); @media ...    │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ layer优先级│ 层间比较 │ 后定义的层 > 先定义的层              │ @layer a,b; → b覆盖a       │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 无层vs有 │ 无层规则 > 所有有层规则              │ .class{} > @layer a{.class │
# │            │ 层       │                                      │ {}}                        │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │!important│ 后定义层仍然优先                     │ @layer b{!imp} > @layer a  │
# │            │          │                                      │ {!imp}                     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 同层内   │ 选择器权重大者胜 / 后定义者胜        │ #id{} > .class{}           │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 优先级排序 │ 1级      │ 无层 + !important（最高）            │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 2级      │ 后层 + !important                    │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 3级      │ 前层 + !important                    │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 4级      │ 无层规则                             │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 5级      │ 后层规则                             │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 6级      │ 前层规则（最低）                     │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 推荐层级   │ reset    │ 重置样式（最低优先级）               │ *{margin:0;padding:0;}     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ base     │ 基础元素样式                         │ body{font:...} h1{...}     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ framework│ 第三方框架                           │ Bootstrap, Tailwind        │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │components│ UI 组件                              │ .button{} .card{}          │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ utilities│ 工具类                               │ .text-center{} .m-0{}      │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │responsive│ 响应式样式                           │@media{@layer responsive{}} │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ theme    │ 主题样式                             │@media(pres-color-scheme){} │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ overrides│ 覆盖样式（最高）                     │ 页面特定样式               │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 完整声明   │ 标准写法 │ 按优先级从低到高                     │ @layer reset,base,framework│
# │            │          │                                      │ ,components,utilities,res  │
# │            │          │                                      │ ponsive,theme,overrides;   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 选择器权重 │ 在层中   │ 取决于层顺序                         │ @layer a{#id{}}(100) <     │
# │            │          │                                      │ @layer b{.class{}}(10)     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 无层     │ 正常计算但 > 所有层                  │ .class{}(10) > @layer a    │
# │            │          │                                      │ {#id{}}(100)               │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 实战应用   │ CSS Reset│ reset层                              │ @layer reset{*{margin:0;   │
# │            │          │                                      │ padding:0;box-sizing:      │
# │            │          │                                      │ border-box;}}              │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 组件库   │ components层                         │ @layer components{.button  │
# │            │          │                                      │ {padding:10px;border:none; │
# │            │          │                                      │ }}                         │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 框架集成 │ framework层                          │ @layer framework{          │
# │            │          │                                      │ /*Bootstrrap*/}            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 工具类   │ utilities层                          │ @layer utilities{.text-    │
# │            │          │                                      │ center{text-align:center;} │
# │            │          │                                      │ }                          │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 主题系统 │ theme层                              │ @layer theme{:root{--color │
# │            │          │                                      │ -primary:#007bff;}}        │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 响应式   │ 多断点系统                           │ @media (min-w:768px)       │
# │            │ 布局     │                                      │ {@layer responsive{        │
# │            │          │                                      │ .container{max-width:720px │
# │            │          │                                      │ ;}}}                       │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 主题切换 │ 媒体查询+层                          │ @media(pres-color-scheme:  │
# │            │          │                                      │ dark){@layer theme{:root   │
# │            │          │                                      │ {--bg-color:#1a1a1a;}}}    │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 打印样式 │ 打印媒体查询                         │ @media print{@layer print  │
# │            │          │                                      │ {body{font-size:12pt;}}}   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────│
# │            │ 第三方库 │ 独立层                               │ @layer library{/*第三方代码│
# │            │          │                                      │ */}                        │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 紧急修复 │ overrides层                          │ @layer overrides{.bug-fix  │
# │            │          │                                      │ {...}}                     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 代码规范   │ 命名     │ 小写字母+连字符                      │ @layer base-components     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 顺序     │ 必须先声明后使用                     │ @layer a,b;放最前面        │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 层级     │ 5-8层为宜                            │ 不宜过多                   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 注释     │ 标注层用途                           │ /*Reset层*/@layer reset{}  │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 文件     │ 按层分文件                           │ reset.css base.css comp.css│
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ @import  │ 必须在最前面                         │ @import url() layer();     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ @media   │ 可在任意位置                         │ 灵活使用                   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 常见错误   │ @import  │ 放在规则后                           │ ✅@import必须在最前面      │
# │            │ 位置错   │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ @media   │ 不清楚用哪种写法                     │ ✅优先用@media包裹@layer   │
# │            │ 嵌套乱   │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 声明太晚 │ 规则后才声明层                       │ ✅在所有规则前声明         │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 使用     │ 破坏层优先级                         │ ✅使用更高层               │
# │            │!important│                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 层级过多 │ 难以维护                             │ ✅合并相似层               │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 无层覆盖 │ 无层规则覆盖所有                     │ ✅将无层规则放入层         │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 层顺序   │ 优先级混乱                           │ ✅按优先级排序             │
# │            │ 错误     │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 最佳实践   │ ✓ DO     │ @import放在最前                      │ @import url() layer();     │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ ✓ DO     │ @media包裹@layer                     │ @media{@layer responsive{}}│
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ ✓ DO     │ 先声明层顺序                         │ @layer a,b;在最前          │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ ✓ DO     │ 按优先级排序                         │ reset→base→components      │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ ✓ DO     │ 使用语义化命名                       │ @layer components{}        │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ ✓ DO     │ 限制层数量                           │ 5-8层                      │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ ✗ DON'T  │ @import放在规则后                    │ 会导致无效                 │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ ✗ DON'T  │ 使用!important                       │ 用更高层替代               │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ ✗ DON'T  │ 混用无层规则                         │ 放入对应层                 │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ ✗ DON'T  │ 创建过多层级                         │ 保持简单                   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 对比其他   │ :where() │ 权重为0                              │ :where(.class{})权重0      │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ :is()    │ 取最高权重                           │ :is(#id,.class{})权重100   │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ @scope   │ 作用域隔离                           │ @scope(.container){}       │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 速查语法   │ @import  │ 导入到层                             │ @import url('a.css')       │
# │            │ url()    │                                      │ layer(a)                   │
# │            │ layer()  │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ @media   │ 媒体查询包裹层                       │ @media{@layer responsive{}}│
# │            │ {@layer  │                                      │                            │
# │            │ {}}      │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ @layer   │ 层内媒体查询                         │ @layer base{@media{}}      │
# │            │ {@media  │                                      │                            │
# │            │ {}}      │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ @layer   │ 声明层                               │ @layer base;               │
# │            │ name;    │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ @layer   │ 声明多层                             │ @layer a,b,c;              │
# │            │ a,b,c;   │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ @layer   │ 定义层                               │ @layer base{body{}}        │
# │            │ name{}   │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────│
# │            │ @layer   │ 嵌套层                               │ @layer a.b{}               │
# │            │ a.b{}    │                                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 核心原则   │ 1        │ @import必须在最前面                  │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 2        │ @media可在任意位置                   │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 3        │ 后定义层>先定义层                    │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 4        │ 无层规则>所有层                      │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 5        │ !important遵循层顺序                 │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 6        │ 同层内按CSS正常规则                  │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │ 一句话总结 │ 核心价值 │ 让CSS优先级清晰可控，解决框架样式    │                            │
# │            │          │ 冲突，支持模块化导入                 │                            │
# ├────────────┼──────────┼──────────────────────────────────────┼────────────────────────────┤
# │            │ 开始使用 │ @layer reset,base,components         │                            │
# │            │          │ ,utilities,overrides;                │                            │
# └────────────┴──────────┴──────────────────────────────────────┴────────────────────────────┘
# 
# ### 权重判断决策树
# ┌────────┬───────────────────┬─────────────────────────────────┬─────────────────────────────────┐
# │  节点  │     判断内容      │              说明               │          处理方式               │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤1  │ 是否有 !important │ 最重要的判断                    │ 有→ 胜出，都无→ 步骤2A          │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤2A │ 是否在层叠层中    │ 区分层叠层和无层叠层            │ 有层→ 2C，无层→ 5 (无层胜有层)  │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤2B │ 比较层叠层顺序    │ 都有 !important 时              │ 不同层→ 后层胜，同层→ 步骤3     │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤2C │ 比较层叠层顺序    │ 有层叠层无 !important           │ 不同层→ 后层胜，同层→ 步骤3A    │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤3  │ 比较基础权重      │ 同层都有 !important             │ 权重高→ 胜出，同权→ 步骤4       │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤3A │ 比较基础权重      │ 有层叠层同层无 !important       │ 权重高→ 胜出，同权→ 步骤4A      │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤4  │ 比较定义顺序      │ 同层同权重都有 !important       │ 后定义胜出                      │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤4A │ 比较定义顺序      │ 有层叠层同层同权重无 !important │ 后定义胜出                      │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤5  │ 是否为行内样式    │ 无层叠层无 !important           │ 行内→ 胜出，非行内→ 步骤6       │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤6  │ 比较选择器权重    │ 无层叠层非行内                  │ 权重高→ 胜出，同权→ 步骤7       │
# ├────────┼───────────────────┼─────────────────────────────────┼─────────────────────────────────┤
# │ 步骤7  │ 比较定义顺序      │ 无层叠层相同权重                │ 行内>内部>外部，同权→ 后定义    │
# └────────┴───────────────────┴─────────────────────────────────┴─────────────────────────────────┘
# 总结一句话 !important 最强 → @layer 其次(无层胜有层) → 权重大者胜 → 后者居上
#
# # 响应式布局
#
# ## @media(媒体查询)
#
# @media 是 CSS 的媒体查询规则，根据设备的特性（如屏幕宽度、高度、分辨率等）应用不同的样式。
# 
# 基本语法如下
# ```css
# @media 媒体类型 逻辑操作符 (媒体特性) {
#   /* CSS 规则 */
# }
# ```
#
#   媒体类型
#
# ┌────────┬──────────────────────────────┬────────────┐
# │  类型  │             说明             │  常用程度  │
# ├────────┼──────────────────────────────┼────────────┤
# │ all    │ 所有设备（默认）             │ ⭐⭐⭐     │
# ├────────┼──────────────────────────────┼────────────┤
# │ screen │ 屏幕设备（电脑、手机、平板） │ ⭐⭐⭐⭐⭐ │
# ├────────┼──────────────────────────────┼────────────┤
# │ print  │ 打印设备                     │ ⭐⭐⭐     │
# ├────────┼──────────────────────────────┼────────────┤
# │ speech │ 语音合成器                   │ ⭐         │
# └────────┴──────────────────────────────┴────────────┘
#
#  常用媒体特性
# ┌────────────────────────┬──────────────┬───────────────────────────────┐
# │          特性          │     说明     │             示例              │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ min-width              │ 最小视口宽度 │ 768px                         │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ max-width              │ 最大视口宽度 │ 768px                         │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ min-height             │ 最小视口高度 │ 800px                         │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ max-height             │ 最大视口高度 │ 800px                         │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ device-width           │ 设备宽度     │ 已废弃                        │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ device-height          │ 设备高度     │ 已废弃                        │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ orientation            │ 方向         │ portrait | landscape          │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ aspect-ratio           │ 宽高比       │ 16/9                          │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ resolution             │ 分辨率       │ min-resolution: 2dppx         │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ min-resolution         │ 最小分辨率   │ min-resolution: 192dpi        │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ max-resolution         │ 最大分辨率   │ max-resolution: 300dpi        │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ scan                   │ 扫描方式     │ interlace | progressive       │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ grid                   │ 网格支持     │ 0 | 1                         │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ display-mode           │ 显示模式     │ fullscreen | standalone       │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ update                 │ 更新频率     │ none | slow | fast            │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ hover                  │ 悬停能力     │ hover | none                  │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ any-hover              │ 任意悬停     │ hover | none                  │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ pointer                │ 指针类型     │ fine | coarse                 │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ any-pointer            │ 任意指针     │ fine | coarse                 │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ color-gamut            │ 色域         │ srgb | p3 | rec2020           │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ color-index            │ 颜色索引     │ 256                           │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ monochrome             │ 单色         │ 0 | 1                         │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ inverted-colors        │ 反转颜色     │ inverted | none               │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ forced-colors          │ 强制颜色     │ active | none                 │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ prefers-color-scheme   │ 颜色主题     │ dark | light                  │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ prefers-reduced-motion │ 动画偏好     │ reduce | no-preference        │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ prefers-reduced-data   │ 数据量偏好   │ reduce | no-preference        │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ prefers-contrast       │ 对比度偏好   │ more | less | custom          │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ overflow-block         │ 块级滚动     │ scroll | optional | none      │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ overflow-inline        │ 内联滚动     │ scroll | optional | none      │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ scripting              │ 脚本支持     │ none | initial-only | enabled │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ transform-3d           │ 3D 变换      │ none | preserve-3d            │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ transition             │ 过渡支持     │ none                          │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ animation              │ 动画支持     │ none                          │
# ├────────────────────────┼──────────────┼───────────────────────────────┤
# │ video-dynamic-range    │ 视频动态范围 │ standard | high               │
# └────────────────────────┴──────────────┴───────────────────────────────┘
#
# 逻辑操作符
# ┌───────────┬────────────────────────┬───────────────────────────────┐
# │  操作符   │          说明          │             示例              │
# ├───────────┼────────────────────────┼───────────────────────────────┤
# │ and       │ 并且（同时满足）       │ screen and (min-width: 768px) │
# ├───────────┼────────────────────────┼───────────────────────────────┤
# │ or (逗号) │ 或者（满足任一）       │ screen, print                 │
# ├───────────┼────────────────────────┼───────────────────────────────┤
# │ not       │ 非（取反）             │ not print                     │
# ├───────────┼────────────────────────┼───────────────────────────────┤
# │ only      │ 仅（防止老浏览器误解） │ only screen and (...)         │
# └───────────┴────────────────────────┴───────────────────────────────┘
#
# 快速参考
#
# ```css
# @media screen and (min-width: 768px) { }/* 基本语法 */
# @media (min-width: 768px) and (max-width: 1024px) { }/* 多条件 */
# @media (min-width: 768px), print { } /* 或条件满足一个即可 */
# @media not print { } /* 非条件 */
# @media (prefers-color-scheme: dark) { } /* 深色模式 */
# @media (prefers-reduced-motion: reduce) { }
# @media (min-width: 576px) { /* ... */ }  /* 大屏手机 */
# @media (min-width: 768px) { /* ... */ }  /* 平板 */
# @media (min-width: 992px) { /* ... */ }  /* 小桌面 */
# @media (min-width: 1200px) { /* ... */ } /* 大桌面 */
# @media print { } /* 打印时 */
# @media screen and (orientation: portrait) { } /* 竖屏 */
# @media screen and (orientation: landscape) { } /* 横屏 */
# @media (prefers-reduced-motion: reduce) { } /* 用户偏好减少动画 */
# /* 高分辨率屏幕 */
# @media (-webkit-min-device-pixel-ratio: 2),(min-resolution: 192dpi) { }
# /* 平板横屏 */
# @media screen and (min-width: 768px) and (orientation: landscape) { }
# @media (min-width: 1200px), print { } /* 大屏幕或打印 */
# @media not print { } /* 非打印设备 */
# ```
#
#
#
